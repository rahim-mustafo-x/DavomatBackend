# Database Configuration
DB_NAME=davomat_db
DB_USERNAME=davomat_user
DB_PASSWORD=changeme_secure_password
DB_PORT_HOST=5433              # Host machine port (external access to PostgreSQL)
DB_PORT_CONTAINER=5432         # Container internal port (PostgreSQL default)

# Application Port
APP_PORT=8080                  # Application will be accessible on this port

# Email Configuration (Gmail)
# Get app password from: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET=change-this-to-a-secure-random-string-minimum-512-bits
