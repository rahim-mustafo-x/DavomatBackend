# ===============================
# Database Configuration
# ===============================
DB_NAME=davomat_db
DB_USERNAME=davomat_user
DB_PASSWORD=your_db_password

# PostgreSQL URL
# Tashqi server:  jdbc:postgresql://192.168.1.x:5432/davomat_db
# Docker ichida:  jdbc:postgresql://postgres:5432/davomat_db
# Local:          jdbc:postgresql://localhost:5432/davomat_db
DB_URL=jdbc:postgresql://localhost:5432/davomat_db

# ===============================
# Application
# ===============================
APP_PORT=8080

# Server IP (boshqa qurilmalardan kirish uchun)
HOST_IP=192.168.1.x

# ===============================
# Email Configuration (Gmail)
# ===============================
# App password olish: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ===============================
# JWT Secret
# ===============================
# Yangi secret yaratish: openssl rand -base64 64
JWT_SECRET=change-this-to-a-secure-random-string-minimum-512-bits